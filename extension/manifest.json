{
  "manifest_version": 3,
  "name": "TimeWhere",
  "version": "0.1.0",
  "description": "个人时间管理与任务规划系统 - TimeWhere for IB Students",
  "options_page": "pages/settings/settings.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "identity",
    "identity.email",
    "alarms",
    "notifications",
    "storage",
    "tabs",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://keystoneacademy.managebac.cn/student/events/*",
    "https://www.googleapis.com/drive/v3/*",
    "https://www.googleapis.com/upload/drive/v3/*"
  ],
  "oauth2": {
    "client_id": "541406150907-rj6d6npl4dnoqcfiaol68tqh8chbpdpg.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.appdata"
    ]
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "TimeWhere"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "shared/**/*",
        "popup/**/*",
        "pages/**/*",
        "fonts/**/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "key": ""
}
