{
  \"name\": \"timewhere\",\n  \"version\": \"0.2.3\",\n  \"description\": \"IB \u5b66\u751f\u4e2a\u4eba\u65f6\u95f4\u7ba1\u7406 Chrome \u6269\u5c55\",\n  \"directories\": {\n    \"doc\": \"docs\"\n  },\n  \"scripts\": {\n    \"serve\": \"npx serve extension -p 3000\",\n    \"electron:dev\": \"npm --prefix platforms/desktop-electron start\",\n    \"electron:smoke\": \"powershell -ExecutionPolicy Bypass -Command \\\"$env:TIMEWHERE_ELECTRON_SMOKE='1'; npm --prefix platforms/desktop-electron start\\\"\",\n    \"electron:package:win\": \"npm --prefix platforms/desktop-electron run package:win\",\n    \"electron:package:mac\": \"npm --prefix platforms/desktop-electron run package:mac\",\n    \"electron:package:mac:remote\": \"gh workflow run timewhere-desktop-mac.yml\",\n    \"package:local\": \"powershell -ExecutionPolicy Bypass -File tools/package-local-unpacked.ps1\",\n    \"package:cws\": \"powershell -ExecutionPolicy Bypass -File tools/package-cws.ps1\",\n    \"test\": \"node tests/scheduling.test.js && node tests/focus.test.js && node tests/calendar.test.js && node tests/taskboard.test.js && node tests/managebac.test.js && node tests/management-review.test.js && node tests/matrixview.test.js && node tests/reminders.test.js && node tests/daily-journal.test.js && node tests/google-sync.test.js && node tests/platform-boundary.test.js && node tests/baseline-safety.test.js\"\n  },\n  \"repository\": {\n    \"type\": \"git\",\n    \"url\": \"git+https://github.com/william-xia-cn/TimelineMg.git\"\n  },\n  \"keywords\": [\"chrome-extension\", \"time-management\", \"IB\"],\n  \"author\": \"\",\n  \"license\": \"ISC\"\n}